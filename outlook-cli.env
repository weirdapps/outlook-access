# ---------------------------------------------------------------------------
# outlook-cli configuration
# ---------------------------------------------------------------------------
# These three settings are MANDATORY. The CLI exits 3 (CONFIG_MISSING) if any
# is unresolved. Per the project's CLAUDE.md rule, there are NO fallback
# defaults — you must set them via one of:
#   1. --timeout / --login-timeout / --chrome-channel CLI flags  (highest)
#   2. env vars below (middle)
#   3. this file, sourced into your shell                        (middle — same
#                                                                 precedence as
#                                                                 env vars, it
#                                                                 just sets
#                                                                 them)
#
# Usage (from this directory):
#   source ./outlook-cli.env
#   node dist/cli.js list-mail
#
# Or one-off:
#   ( source ./outlook-cli.env && node dist/cli.js list-mail )
#
# Or export for the whole shell session:
#   . ./outlook-cli.env
#
# To make permanent, append `source /path/to/outlook-cli.env` to your
# ~/.zshrc or ~/.bashrc.
# ---------------------------------------------------------------------------

# Per-REST-call HTTP timeout in milliseconds.
# Must be a positive integer. 30 seconds is comfortable for Outlook.
export OUTLOOK_CLI_HTTP_TIMEOUT_MS=30000

# Maximum time (ms) to wait for the user to complete interactive login in the
# Playwright-controlled Chrome window. 5 minutes handles MFA / conditional
# access comfortably.
export OUTLOOK_CLI_LOGIN_TIMEOUT_MS=300000

# Playwright Chrome channel. Valid values depend on installed browsers:
#   chrome       — Google Chrome stable (most common)
#   chrome-beta  — Google Chrome Beta
#   chrome-dev   — Google Chrome Dev
#   msedge       — Microsoft Edge
#   msedge-beta  — Microsoft Edge Beta
# If unsure, leave as `chrome`.
export OUTLOOK_CLI_CHROME_CHANNEL=chrome

# ---------------------------------------------------------------------------
# Optional overrides (comment-out to keep defaults)
# ---------------------------------------------------------------------------

# Override the session file location. Default: $HOME/.outlook-cli/session.json
# export OUTLOOK_CLI_SESSION_FILE="$HOME/.outlook-cli/session.json"

# Override the Playwright profile directory.
# Default: $HOME/.outlook-cli/playwright-profile
# export OUTLOOK_CLI_PROFILE_DIR="$HOME/.outlook-cli/playwright-profile"
